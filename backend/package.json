{
  "name": "ocd-crochet-backend",
  "version": "1.0.0",
  "description": "Backend for OCD Crochet Shopify Dashboard",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky install"
  },
  "keywords": [
    "shopify",
    "dashboard",
    "order-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.3",
    "@shopify/shopify-api": "^11.12.0",
    "@types/jest": "^29.5.14",
    "@types/mongoose": "^5.11.96",
    "@types/supertest": "^6.0.3",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jest": "^29.7.0",
    "jwks-rsa": "^3.2.0",
    "mongoose": "^8.14.1",
    "morgan": "^1.10.0",
    "supertest": "^7.1.0",
    "tree-kill": "^1.2.2",
    "ts-jest": "^29.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "husky": "^8.0.0",
    "prettier": "^3.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
