# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-jwt-secret

# Shopify Configuration
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SHOP_NAME=your-shop-name
SHOPIFY_SHOP_DOMAIN=your-shop-domain
SHOPIFY_SHOP_URL=your-shop-url
SHOPIFY_ACCESS_TOKEN=your-access-token
SHOPIFY_API_VERSION=2023-10
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Shipping Configuration
SHIPPING_USERNAME=your-shipping-username
SHIPPING_PASSWORD=your-shipping-password
SHIPPING_API_URL=your-shipping-api-url
SHIPPING_MERCHANT_ID=your-merchant-id
SHIPPING_MEMBER_ID=your-member-id

# WhatsApp — WABA (Meta Cloud API). Set false to use Messaging hub + WhatsApp Web only.
WHATSAPP_WABA_ENABLED=false
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-id
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# WhatsApp Web (Baileys) — automated order-confirmed messages from your Business app number
WHATSAPP_WEB_ENABLED=true
WHATSAPP_WEB_AUTH_DIR=data/whatsapp-web-auth
# Order confirmation delay (ms). Default 3600000 = 1 hour. Use 0 for instant send (testing only).
# ORDER_CONFIRMATION_DELAY_MS=3600000
# Optional: require X-WhatsApp-Web-Secret header on /api/whatsapp/web/* (set same value in VITE_WHATSAPP_WEB_ADMIN_SECRET)
WHATSAPP_WEB_ADMIN_SECRET=

# Discord Notifications
DISCORD_WEBHOOK_URL=your-discord-webhook-url
DISCORD_WHATSAPP_WEBHOOK_URL=your-discord-whatsapp-webhook-url
DISCORD_PUBLIC_KEY=your-discord-bot-public-key
# Optional: For interactive buttons, use bot instead of webhook
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_WHATSAPP_CHANNEL_ID=your-discord-channel-id
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100 